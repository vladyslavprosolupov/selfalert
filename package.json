{
  "name": "selfalert",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "cf:dev": "pnpm --filter @selfalert/api run dev:cloudflare",
    "cf:deploy": "pnpm --filter @selfalert/api run deploy",
    "cf:typegen": "pnpm --filter @selfalert/api run cf-typegen",
    "dev": "turbo dev --parallel",
    "dev:api:cloudflare": "pnpm --filter @selfalert/api run dev:cloudflare",
    "dev:api:node": "pnpm --filter @selfalert/api run dev:node",
    "dev:dashboard": "pnpm --filter @selfalert/dashboard run dev",
    "docker:migrate": "docker compose -f infra/docker/docker-compose.yml run --rm app pnpm --filter @selfalert/api run db:apply:node",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up --build",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "lint": "turbo lint",
    "format": "turbo format",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/md5": "^2.3.5",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "~4.1.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.13.0"
  }
}
