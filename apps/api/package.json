{
  "name": "@selfalert/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "dev": "pnpm dev:cloudflare",
    "dev:cloudflare": "wrangler dev --config ../../infra/cloudflare/wrangler.jsonc --env-file ../../.env",
    "dev:node": "tsx watch src/server.ts",
    "deploy": "wrangler deploy --config ../../infra/cloudflare/wrangler.jsonc",
    "start:node": "tsx src/server.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier . --write --ignore-unknown",
    "cf-typegen": "wrangler types ../../infra/cloudflare/worker-configuration.d.ts --config ../../infra/cloudflare/wrangler.jsonc",
    "db:create": "wrangler d1 create --config ../../infra/cloudflare/wrangler.jsonc",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:apply:cloudflare": "wrangler d1 migrations apply --config ../../infra/cloudflare/wrangler.jsonc",
    "db:apply:node": "tsx src/platform/node/migrate.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@hono/node-server": "^1.19.10",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.4",
    "@selfalert/core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260329.1",
    "@types/node": "^25.1.0",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.6",
    "wrangler": "^4.78.0"
  }
}
